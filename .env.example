NODE_ENV=development
PORT=3000
RUNPOD_PROVIDER=mock
RUNPOD_API_BASE=https://rest.runpod.io/v1
RUNPOD_API_KEY=
RUNPOD_POD_ID=local-worker
RUNPOD_SERVICE_URL=http://127.0.0.1:8000
RUNPOD_READY_PATH=/ready
# Trusted worker registry. Leave empty for the legacy Pod, or set [] for a dynamic-only pool.
RUNPOD_WORKERS_JSON=
# Default Context model shortcut, including a dynamic-only pool. Prefer the JSON map for multiple models.
RUNPOD_TEMPLATE_ID=
# Preferred for multi-model provisioning: [{"model_id":"...","runtime":"realtime","template_id":"...","max_sessions":32}]
RUNPOD_MODEL_TEMPLATES_JSON=
# Required when live provisioning Context realtime or any batch template; it carries catalogs, private repos, base weights, and ECAPA assets.
RUNPOD_NETWORK_VOLUME_ID=
# Keep dynamically-created Pods running after a session unless an operator explicitly opts in.
RUNPOD_AUTO_STOP_IDLE=false
RUNPOD_POOL_MAX_WORKERS=4
RUNPOD_WORKER_PORT=8000
RUNPOD_GPU_TYPES=NVIDIA A100 80GB PCIe,NVIDIA A100-SXM4-80GB
# Set all secrets to independent random values of at least 32 characters in every production mode.
RUNPOD_WORKER_ADMIN_SECRET=
WORKER_TICKET_SECRET=
WORKER_TICKET_TTL_SECONDS=120
WORKER_LEASE_SECONDS=900
WORKER_PROVISION_TIMEOUT_SECONDS=300
WORKER_RECONCILE_INTERVAL_MS=10000
WORKER_REAPER_INTERVAL_MS=30000
CONTROL_PASSWORD=change-me
SESSION_SECRET=change-me-to-at-least-32-characters
SESSION_TTL_SECONDS=43200
ALLOWED_ORIGIN=http://localhost:3000
TRANSCRIPT_STORAGE=auto
DATABASE_URL=
TRANSCRIPT_RETENTION_DAYS=30
TRANSCRIPT_STALE_MINUTES=10
MOCK_INITIAL_STATUS=EXITED
MOCK_READY_DELAY_MS=2500
