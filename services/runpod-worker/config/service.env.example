# Identity is supplied by Railway/RunPod. RUNPOD_POD_ID is used when WORKER_ID is absent.
MODEL_ID=infodeliverailab/qwen3-asr-ja-rlbr-context-fullft
WORKER_RUNTIME=realtime
WORKER_ID=
WORKER_TICKET_SECRET=
REQUIRE_WORKER_TICKET=true
WORKER_ADMIN_SECRET=
DRAINING=false

ASR_BACKEND=qwen_async_vllm
SERVICE_PROFILE=production
ASR_MODEL=/workspace/models/qwen3-asr-ja-rlbr-context-fullft
ASR_DTYPE=bfloat16
ALIGNER_MODEL=/workspace/models/Qwen3-ForcedAligner-0.6B
ENABLE_ALIGNER=true
COMPILE_ALIGNER=true
WARMUP_ALIGNER=true
GPU_MEMORY_UTILIZATION=0.72

DIARIZER_BACKEND=sortformer_remote
DIARIZER_MODEL=/workspace/models/diar_streaming_sortformer_4spk-v2.1-verified/diar_streaming_sortformer_4spk-v2.1.nemo
DIARIZER_URL=http://127.0.0.1:18001/diarize
DIARIZER_BATCH_SIZE=32
DIARIZER_BATCH_WINDOW_MS=12
DIARIZER_SIDECAR_QUEUE_SIZE=64
DIARIZER_MAX_PCM_CHUNK_SECONDS=2
DIARIZER_SIDECAR_REQUEST_TIMEOUT_SECONDS=3.5
DIARIZER_CHUNK_FRAMES=6
DIARIZER_SPEAKER_CACHE_FRAMES=188
DIARIZER_FIFO_FRAMES=188
DIARIZER_SPEAKER_CACHE_UPDATE_FRAMES=144
DIARIZER_STREAM_TTL_SECONDS=120

MODELS_LOCK_PATH=/opt/app/config/models.lock.json
BOOTSTRAP_MODELS=true
HF_HOME=/workspace/cache/huggingface
HUGGINGFACE_HUB_CACHE=/workspace/cache/huggingface/hub
VLLM_CACHE_ROOT=/workspace/cache/vllm
CATALOG_PATH=/workspace/config/terms.json

MAX_SESSIONS=32
SESSION_START_TIMEOUT_SECONDS=10
MAX_PCM_FRAME_MS=1000
MAX_STREAM_AUDIO_SECONDS=14400
MAX_AUDIO_LEAD_SECONDS=5
MAX_SESSION_SECONDS=14700
MAX_SESSION_JOBS=8
MAX_SESSION_EVENTS=32
CHUNK_SECONDS=1.0
VAD_END_SILENCE_MS=480
ROLLBACK_TOKENS=5
PARTIAL_MAX_NEW_TOKENS=32
FINAL_MAX_NEW_TOKENS=512
BATCH_WINDOW_MS=15
BATCH_SIZE=32
SCHEDULER_QUEUE_SIZE=64
SCHEDULER_MAX_CONCURRENT_BATCHES=2
LABEL_DELAY_MS=320
DIARIZER_INTERVAL_MS=500
DIARIZER_MAX_CHUNK_SECONDS=1.5
FINAL_DIARIZATION_TIMEOUT_SECONDS=4
DIARIZER_REQUEST_TIMEOUT_SECONDS=4
DIARIZER_CLEANUP_TIMEOUT_SECONDS=0.5
CONTEXT_TOP_K=20
CONTEXT_MAX_UPDATES=2
ACCELERATOR_LABEL=RunPod GPU

# Batch-only overrides for infodeliverailab/lab_asr_diarization_v1.
# LAB_ALLOWED_ORIGINS must contain exact origins; "*" is rejected.
# The bootstrap downloads these paths at pinned revisions on first start.
LAB_BOOTSTRAP_ROOT=/workspace/lab-asr-poc
LAB_BOOTSTRAP_MANIFEST=/workspace/lab-asr-poc/.lab-batch-models.json
LAB_MODEL_DOWNLOAD_LOCK=/workspace/lab-asr-poc/.lab-batch-download.lock
LAB_REPO_PATH=/workspace/lab-asr-poc/lab_asr_diarization_v1
LAB_REPO_REVISION=651c6d0f303557332293afa9fa15e1dd30456606
LAB_PYTHON=/opt/venvs/asr/bin/python
BASE_MODEL_DIR=/workspace/lab-asr-poc/base_model
LAB_ECAPA_DIR=/workspace/lab-asr-poc/pretrained_ecapa
LAB_CHECKPOINT_PATH=/workspace/lab-asr-poc/lab_asr_diarization_v1/weights/interleave.pt
LAB_ALLOWED_ORIGINS=https://replace-with-asr-studio.example
LAB_MAX_UPLOAD_BYTES=268435456
LAB_MAX_AUDIO_SECONDS=120
LAB_DEFAULT_MAX_NEW_TOKENS=800
LAB_HARD_MAX_NEW_TOKENS=1024
LAB_MAX_REQUEST_OVERHEAD_BYTES=1048576
LAB_TEMP_DIR=/tmp/infodeliver-lab-batch
LAB_TEMP_MAX_AGE_SECONDS=3600
LAB_DEVICE=cuda:0
LAB_DTYPE=bfloat16
LAB_ECAPA_BATCH=256
LAB_BLOCK_SECONDS=1.2
LAB_SPEAKER_TOKENS_PER_BLOCK=4
