{
  "name": "qwen3-asr-lab-batch-worker",
  "imageName": "ghcr.io/<owner>/qwen3-asr-runpod-worker@sha256:<verified-digest>",
  "category": "NVIDIA",
  "containerDiskInGb": 40,
  "containerRegistryAuthId": "<runpod-registry-auth-id>",
  "dockerEntrypoint": [],
  "dockerStartCmd": [],
  "env": {
    "MODEL_ID": "infodeliverailab/lab_asr_diarization_v1",
    "WORKER_RUNTIME": "batch",
    "LAB_BOOTSTRAP_ROOT": "/workspace/lab-asr-poc",
    "LAB_BOOTSTRAP_MANIFEST": "/workspace/lab-asr-poc/.lab-batch-models.json",
    "LAB_MODEL_DOWNLOAD_LOCK": "/workspace/lab-asr-poc/.lab-batch-download.lock",
    "LAB_REPO_PATH": "/workspace/lab-asr-poc/lab_asr_diarization_v1",
    "LAB_REPO_REVISION": "651c6d0f303557332293afa9fa15e1dd30456606",
    "LAB_PYTHON": "/opt/venvs/asr/bin/python",
    "BASE_MODEL_DIR": "/workspace/lab-asr-poc/base_model",
    "LAB_ECAPA_DIR": "/workspace/lab-asr-poc/pretrained_ecapa",
    "LAB_CHECKPOINT_PATH": "/workspace/lab-asr-poc/lab_asr_diarization_v1/weights/interleave.pt",
    "LAB_ALLOWED_ORIGINS": "https://replace-with-asr-studio.example",
    "LAB_MAX_AUDIO_SECONDS": "120",
    "LAB_DEVICE": "cuda:0",
    "LAB_DTYPE": "bfloat16",
    "REQUIRE_WORKER_TICKET": "true",
    "DRAINING": "false",
    "MAX_SESSIONS": "1",
    "PORT": "8000",
    "HF_TOKEN": "{{ RUNPOD_SECRET_hf_token }}",
    "WORKER_TICKET_SECRET": "{{ RUNPOD_SECRET_worker_ticket_secret }}",
    "WORKER_ADMIN_SECRET": "{{ RUNPOD_SECRET_worker_admin_secret }}"
  },
  "isPublic": false,
  "isServerless": false,
  "ports": ["8000/http"],
  "readme": "InfoDeliver lab batch worker. Attach the shared network volume at /workspace when creating the Pod.",
  "volumeInGb": 0,
  "volumeMountPath": "/workspace"
}
